{
    "tagFormat": "v${version}",
    "branches": [
        "main",
        {
           "name": "develop",
           "channel": "dev",
           "prerelease": "dev"
        }
    ],
    "plugins": [
        ["@semantic-release/commit-analyzer", {
            "preset": "conventionalcommits",
            "releaseRules": [
                { "breaking": true, "release": "major" },
                { "revert": true, "release": "patch" },
                { "type": "feat", "release": "minor" },
                { "type": "fix", "release": "patch" },
                { "type": "perf", "release": "patch" },
                { "type": "refactor", "release": "patch"},
                { "type": "build", "release": "patch"},
                { "type": "chore", "release": "patch"},
                { "type": "test", "release": "patch"},
                { "type": "ci", "release": false },
                { "type": "docs", "release": false },
                { "scope": "no-release", "release": false }
            ]
        }],
        ["@semantic-release/release-notes-generator", {
            "preset": "conventionalcommits",
            "presetConfig":{
                "types": [
                    { "type": "feat", "section": "Features"},
                    { "type": "fix", "section": "Bug Fixes"},
                    { "type": "refactor", "hidden": false, "section": "Refactor"},
                    { "type": "perf", "hidden": false, "section": "Refactor"},
                    { "type": "test", "hidden": false, "section": "Tests"},
                    { "type": "ci", "hidden": false, "section": "Build projects"},
                    { "type": "build", "hidden": false, "section": "Build projects"}
                ]
            }
        }],
        ["@semantic-release/exec", {
            "verifyReleaseCmd": "echo ${nextRelease.version} > .VERSION"
        }],
        "@semantic-release/changelog",
        "@semantic-release/gitlab"
    ]
}
